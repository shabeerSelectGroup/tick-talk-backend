# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-min-32-chars
APP_DEBUG=true
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_PUBLIC_URL=http://localhost:5173
# Production example:
# APP_ENV=production
# APP_CORS_ORIGINS=https://ticktalk.thegamearcade.com
# APP_PUBLIC_URL=https://ticktalk.thegamearcade.com

# Database — must use mysql+aiomysql (not mysql://); URL-encode special chars in password
# Use 3308/6381 when docker-compose.yml maps those ports (default in this repo)
DATABASE_URL=mysql+aiomysql://ticktalk:ticktalk@localhost:3308/ticktalk

# Redis — use 6381 only with docker-compose port mapping; bare metal/server use 6379
REDIS_URL=redis://localhost:6381/0
# Production on same host: REDIS_URL=redis://localhost:6379/0

# Admin portal (shared code — change in production)
ADMIN_SECURITY_CODE=changeme-admin
ADMIN_LOGIN_EMAIL=admin@ticktalk.app

# JWT (Admin)
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# Participant session
SESSION_EXPIRE_HOURS=24

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ticktalk-selfies
R2_PUBLIC_URL=
R2_ENDPOINT_URL=

# Selfie processing (optional)
SELFIE_MAX_UPLOAD_BYTES=8388608
SELFIE_JPEG_QUALITY=90
SELFIE_MAX_DIMENSION=1920
SELFIE_THUMBNAIL_SIZE=480
LOCAL_STORAGE_DIR=storage/uploads
LOCAL_STORAGE_PUBLIC_BASE=http://localhost:8000/api/v1/media

# Web Push — npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ticktalk.app
